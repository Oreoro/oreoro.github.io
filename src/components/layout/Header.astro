---
import { siteInfo } from "@/site.config";
import { getNavLink } from "@/lib/blog-helpers";

const displayTitle = siteInfo.title || "Blog";
---

<header id="main-header" class="site-header">
	<a
		href={getNavLink("/")}
		class="site-brand"
		aria-current={Astro.url.pathname === "/" ? "page" : false}
	>
		{displayTitle}
	</a>
	<nav class="site-header-actions" aria-label="Primary navigation">
		<a class="site-header-link" href={getNavLink("/contact/")}>CONTACT</a>
		<a class="site-header-link" href={getNavLink("/rss.xml")}>RSS</a>
		<a class="site-header-link" href={getNavLink("/donate/")}>DONATE</a>
	</nav>
</header>
